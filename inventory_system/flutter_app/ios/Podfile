# Podfile for Stock Inventory Flutter Application
platform :ios, '12.0'

# Disable CocoaPods analytics for faster build times in cloud CI/CD
disable_cocoapods_analytics!

# Use project-defined source
target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Force unified deployment target across all pods to avoid compilation warnings/errors
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
      
      # Bitcode is deprecated by Apple and disabled in modern Xcode versions
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      
      # Fix Xcode 15+ signing issue for resource bundles
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
end
